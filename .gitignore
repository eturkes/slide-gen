# Claude Code — track shared settings.json, ignore machine-local override
.claude/settings.local.json
# Headroom live-wrap marker (ephemeral pid/port/env key; per session, removed on exit)
.claude/.headroom_wrap_marker.json

# Python / uv (per-layer envs)
.venv/
.venv-host/
__pycache__/
*.py[cod]

# Node / pnpm
node_modules/

# direnv
.direnv/

# MoonBit (build output, fetched deps, toolchain agent state)
_build/
target/
.mooncakes/
.moonagent/

# Headroom tokensave code-graph state (regenerable; Serena's self-ignores via .serena/.gitignore)
.tokensave/

# slide-gen runtime state + generated decks
enabled.txt
enabled.txt.tmp
decks/
